<% layout('layout/boilerplate') -%>
<h1>Single Product page</h1>
<div class="row">
    <div class="col-lg-6">
            <div class="card" style="width: 18rem;">
                <img src="<%= product.image %>" class="card-img-top" alt="...">
                <div class="card-body">
                    <h5 class="card-title"><%= product.title  %></h5>
                    <h5 class="card-title"><%= product.price  %></h5>
                    <p class="card-text"><%= product.description  %></p>
                    <% if(currUser.usertype == "seller"){ %>
                        <a href="/edit/<%= product._id  %>" class="btn btn-danger">Edit</a>
                        <form action="/product/<%= product._id%>?_method=DELETE" method="post">
                        <button type="submit" class="btn btn-success">Delete</buton>
                        </form>
                    <% }else{ %>
                        <a href="#" class="btn btn-primary">Buy</a>
                        <a href="/cart/<%= product._id %>" class="btn btn-warning">Add to cart</a>
                    <% } %>
                </div>
            </div>     
    </div>
    <div class="col-lg-6">
        <h2>Review</h2>
        <form action="/review/<%= product._id  %>" method="post">
        <div class="form-group">
            <label for="comment">Comment</label>
            <input type="text" class="form-control" id="comment" placeholder="Enter comment" name="comment">
        </div>
        <div class="form-group">
            <label for="range3" class="form-label">Rating</label>
            <input type="range" class="form-range" min="0" max="5" step="0.5" id="range3" name="rating">
        </div>
        <button type="submit" class="btn btn-primary">Submit</button>
        </form>
        <% for(let review of product.reviews){ %>
            <div class="row">
                <div class="col-lg-12 mx-4">
                    <div class="card">
                    <div class="card-body">
                        <h5 class="card-title"><%= review.comment %></h5>
                        <p class="card-text"><%= review.rating %></p>
                        <a href="#" class="btn btn-danger">Delete</a>
                    </div>
                    </div>
                </div>
        <% } %>
    </div>
</div>
  